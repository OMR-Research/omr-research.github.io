  booktitle = {5th International Conference on Digital Libraries for Musicology},
  title     = {Scores of Scores: An Openscore Project to Encode and Share Sheet Music},
  year      = {2018},
  address   = {Paris, France},
  pages     = {87--95},
  publisher = {ACM},
  acmid     = {3273026},
