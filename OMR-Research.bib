}

@Article{Wu2025,
  author   = {Wu, Jinghao and Guo, Wei},
  journal  = {Acoustical Science and Technology},
  title    = {Autoregressive {ConvNeXt}-Transformer Fusion Framework for Polyphonic Optical Music Recognition with Focal Loss Optimization},
  year     = {2025},
  issn     = {1346-3969},
  abstract = {This paper proposes the {ConvNeXt}-Transformer Fusion ({CNTF}) framework, an autoregressive end-to-end neural network employing an image-to-sequence architecture optimized for automated transcription of intricate musical scores. It integrates a {ConvNeXt}-based encoder for sheet music feature extraction and a Transformer-based decoder that generates transcription sequences through autoregressive prediction. Focal Loss optimization is implemented to address class imbalance during training. Experimental results demonstrate state-of-the-art performance in polyphony-rich score recognition.},
