@Article{Setyo2024,
  author   = {Setyo, Ciara and Kusuma, Gede Putra},
  journal  = {International Journal of Electrical and Computer Engineering},
  title    = {Recognition of Music Symbol Notation Using Convolutional Neural Network},
  year     = {2024},
  month     = {Apr},
  number   = {2},
  pages    = {2055--2067},
  volume   = {14},
  abstract = {Musical notation is one thing that needs to be learned to play music. This notation has an important role in music because it can help in visualizing instructions for playing musical instruments and singing. Unfortunately, musical symbols that are commonly written in musical notation are difficult for beginners who have just started learning music. This research proposed a solution to create an optical music recognition (OMR) using a deep learning model to classify musical notes more accurately with some of the latest convolutional neural network (CNN) architectures. The research was carried out by implementing vision transformer (ViT), CoAtNet-0, and ConvNeXtTiny architecture. The training process was also combined with data augmentation to provide more information for the model to learn. The best accuracy for the Andrea dataset is 98.15\% and for the Attwenger dataset is 98.43\%.},
  doi      = {10.11591/ijece.v14i2.pp2055-2067},
  file     = {:pdfs/2024 - Recognition of Music Symbol Notation Using Convolutional Neural Network.pdf:PDF},
  issn     = {2088-8708},
  url      = {https://ijece.iaescore.com/index.php/IJECE/article/view/33969},
}

