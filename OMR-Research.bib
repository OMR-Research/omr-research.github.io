  url       = {https://sites.google.com/view/worms2023/proceedings},
  abstract  = {The International Workshop on Reading Music Systems (WoRMS) is a workshop that tries to connect researchers who develop systems for reading music, such as in the field of Optical Music Recognition, with other researchers and practitioners that could benefit from such systems, like librarians or musicologists. The relevant topics of interest for the workshop include, but are not limited to: Music reading systems; Optical music recognition; Datasets and performance evaluation; Image processing on music scores; Writer identification; Authoring, editing, storing and presentation systems for music scores; Multi-modal systems; Novel input-methods for music to produce written music; Web-based Music Information Retrieval services; Applications and projects; Use-cases related to written music. These are the proceedings of the 5th International Workshop on Reading Music Systems, held in Milan, Italy on Nov. 4th 2023.},
}

@MastersThesis{MartinezSevilla2023b,
  author = {Mart{\'\i}nez-Sevilla, Juan Carlos},
  school = {Universitat d'Alacant (University of Alicante)},
  title  = {{SheetVision}. Aplicaci{\'o}n para el reconocimiento {\'o}ptico de m{\'u}sica},
  year   = {2023},
  month  = {Jun},
  file   = {:pdfs/2023 - SheetVision. Aplicacion Para El Reconocimiento Optico De Musica.pdf:PDF},
  url    = {https://rua.ua.es/entities/publication/33084f08-dd37-4e0d-8aef-7b440d8f3f5c},
  abstract  = {Mucha de la música escrita se encuentra tan solo en formato físico, almacenada en volúmenes históricos. La digitalización de imágenes llevada a cabo, de manera masiva, por bibliotecas con fondos musicales es tan sólo el primer paso de la transición digital necesaria para que las partituras puedan ser transmitidas, copiadas y visualizadas sin sufrir ningún deterioro. Además simples imágenes no permiten a ningún algoritmo de búsqueda, clasificación o musicología digital trabajar, por lo que es necesario aplicar sobre estos documentos técnicas en inteligencia artificial capaces de extraer la información musical asociada. Esta tecnología es conocida como Optical Music Recognition (OMR) y es la encargada de convertir una imagen en un formato estructurado musical. En este proyecto se propone la creación de un sistema de este tipo sobre la plataforma iOS, que deberá integrar los modelos de reconocimiento automático necesarios para una recuperación de la información musical óptima.},
}

@InProceedings{MartinezSevilla2025,
  author     = {Martinez-Sevilla, Juan C. and Foscarin, Francesco and Garcia-Iasci, Patricia and Rizo, David and Calvo-Zaragoza, Jorge and Widmer, Gerhard},
  booktitle  = {Proceedings of the 26th International Society for Music Information Retrieval Conference},
