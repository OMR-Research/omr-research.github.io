  author   = {Ferano, Francisco Calvin Arnel and Zahra, Amalia and Kusuma, Gede Putra},
  journal  = {Bulletin of Electrical Engineering and Informatics},
  title    = {Stacking Ensemble Learning for Optical Music Recognition},
  year     = {2023},
