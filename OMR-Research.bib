@InProceedings{Calvo-Zaragoza2018d,
  author    = {Calvo-Zaragoza, Jorge and Haji{\v{c}} jr., Jan and Pacha, Alexander},
  booktitle = {Graphics Recognition, Current Trends and Evolutions},
